# =============================================================================
# RC Tractoparts — Quotation Management System
# Environment Variables Reference — Copy this file to .env and fill in values
#
#   cp .env.example .env        # Linux/macOS
#   Copy-Item .env.example .env # Windows PowerShell
#
# SECURITY: NEVER commit the real .env file. All secrets, encryption keys and
# credentials MUST be supplied here at runtime — nothing is hardcoded in source,
# the Dockerfile, or docker-compose.yml.
# =============================================================================

# --- Application ---
NODE_ENV=development          # development | production | test
PORT=3000                     # HTTP port the Express server listens on
APP_NAME=RC-Tractoparts-API

# --- Database (MySQL) ---
# In Docker Compose, DB_HOST is overridden to the "db" service name automatically.
# For a non-Docker local run, keep localhost.
DB_HOST=localhost
DB_PORT=3306
DB_USER=rc_user
DB_PASSWORD=change_me_use_a_strong_db_password
DB_NAME=rc_tractoparts
DB_NAME_TEST=rc_tractoparts_test  # Database used for automated tests

# Root password for the MySQL container (docker-compose "db" service only).
# Required by docker-compose.yml; unused for a non-Docker local MySQL server.
DB_ROOT_PASSWORD=change_me_use_a_strong_root_password

# Connection pool tuning
DB_CONNECTION_LIMIT=10        # Maximum simultaneous connections in the pool
DB_QUEUE_LIMIT=0              # 0 = unlimited queue; adjust under heavy load

# --- Authentication & Security ---
# Generate a strong secret, e.g.:  openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=8h             # Token lifetime (8 hours = one full work day)

BCRYPT_ROUNDS=12              # bcrypt cost factor; increase on faster hardware

# --- Brute-force protection ---
MAX_LOGIN_ATTEMPTS=3          # Consecutive failures before account lock
LOCK_DURATION_MINUTES=15      # Duration of the account lock in minutes

# --- File uploads (PDF) ---
UPLOAD_DIR=uploads/cotizaciones
MAX_PDF_SIZE_MB=10            # Maximum PDF file size in megabytes

# --- CORS ---
# Public domain(s) served through Nginx in production; comma-separated.
# Example (production): https://cotizaciones.tudominio.com
CORS_ORIGIN=http://localhost:5500   # Allowed frontend origin(s); comma-separated for multiple

# --- Initial account provisioning (scripts/seed-users.js) ---
# sql/init.sql seeds the three initial accounts LOCKED (no usable hash).
# Set strong passwords here (min 10 chars) and run `npm run seed:execute`
# to activate them. Re-run with new values any time to ROTATE passwords.
# NEVER commit the real .env.
SEED_SYSADMIN_PASSWORD=change_me_strong_password_sysadmin
SEED_JEFE_PASSWORD=change_me_strong_password_jefe
SEED_ADMIN_PASSWORD=change_me_strong_password_admin
