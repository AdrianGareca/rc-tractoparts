{
  "name": "rc-tractoparts-api",
  "version": "1.0.0",
  "description": "RC Tractoparts — Quotation Management System REST API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "db:init": "node sql/init.js",
    "db:migrate": "echo 'No standalone migrations: sql/init.sql is the single source of truth. Run: npm run db:init'",
    "seed": "node scripts/seed-users.js",
    "seed:execute": "node scripts/seed-users.js --execute",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "pdfkit": "^0.18.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "globals": "^13.24.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "RC Tractoparts — Departamento de Sistemas",
  "license": "UNLICENSED"
}
